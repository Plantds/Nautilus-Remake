  - {fileID: 114350483966675077}
  m_OperatorName: Custom HLSL
  m_HLSLCode: "struct BoidsParticle\n{\n  float3 Position;\n  float3 Velocity;\n}\n\nfloat3
    GetPosition(in uint particleId, in StructuredBuffer<BoidsParticle> currBuffer)\n{\n 
    return currBuffer[ particleId ].Position;\n}\n\nfloat3 GetPositionInterpolated(in
    uint particleId, float progress, in StructuredBuffer<BoidsParticle> prevBuffer,\n 
    in StructuredBuffer<BoidsParticle> currBuffer)\n{\n  return lerp( prevBuffer[particleId].Position,
    currBuffer[particleId].Position, progress );\n}"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunctions:
    selection: GetPositionInterpolated
    selectedIndex: 1
