  m_ActivationSlot: {fileID: 114350483966675067}
  m_BlockName: Custom HLSL
  m_HLSLCode: "struct BoidsParticle\n{\n  float3 Position;\n  float3 Velocity;\n}\n\nvoid
    InitParticle(inout VFXAttributes attributes, RWStructuredBuffer<BoidsParticle>
    boidsBuffer, float3 velocity)\n{\n  boidsBuffer[attributes.particleId].Position
    = attributes.position;\n  boidsBuffer[attributes.particleId].Velocity = velocity;\n}"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunction:
    selection: InitParticle
    selectedIndex: 0
