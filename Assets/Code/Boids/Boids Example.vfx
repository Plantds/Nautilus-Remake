  m_EditorClassIdentifier: Unity.VisualEffectGraph.Editor::UnityEditor.VFX.Operator.CustomHLSL
  m_UIIgnoredErrors: []
  m_Parent: {fileID: 114350483966674976}
  m_Children: []
  m_UIPosition: {x: -2208, y: 1389}
  m_UICollapsed: 0
  m_UISuperCollapsed: 0
  m_InputSlots:
  - {fileID: 114350483966675107}
  - {fileID: 114350483966675108}
  - {fileID: 114350483966675109}
  - {fileID: 114350483966675110}
  m_OutputSlots:
  - {fileID: 114350483966675111}
  m_OperatorName: Custom HLSL
  m_HLSLCode: "struct BoidsPartiocle\n{\n  float3 Position;\n  float3 Velocity;\n}\n\nfloat3
    GetVelocity(in uint particleId, in StructuredBuffer<BoidsParticle> currBuffer)\n{\n 
    return currBuffer[ particleId ].Velocity;\n}\n\nfloat3 GetVelocityInterpolated(in
    uint particleId, float progress, in StructuredBuffer<BoidsParticle> prevBuffer,\n 
    in StructuredBuffer<BoidsParticle> currBuffer)\n{\n  return lerp( prevBuffer[particleId].Velocity,
    currBuffer[particleId].Velocity, progress );\n}"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunctions:
    selection: GetVelocityInterpolated
    selectedIndex: 1
